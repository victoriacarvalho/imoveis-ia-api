
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  VENDA
  ALUGUEL
}

enum PropertyType {
  APARTAMENTO
  CASA
  COMERCIAL
  LOTE
  REPUBLICA
  QUARTO
}

enum PropertyStatus {
  DISPONIVEL
  ALUGADO
  VENDIDO
  INATIVO
}

enum LeadOrigin {
  BOTAO_AGENDAR
  CHAT_IA
}

enum LeadStatus {
  NOVO
  ENVIADO_IMOBILIARIA
  VISITA_FEITA
}

model User {
  id             String     @id
  name           String?
  email          String     @unique
  emailVerified  Boolean    @default(false)
  image          String?
  isAdmin        Boolean    @default(false)

  plan           String?    @default("Plano Básico")
  bedrooms       Int?
  parkingSpots   Int?
  bathrooms      Int?
  neighborhood   String?
  onboardingDone Boolean    @default(false)

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  favorites      Favorite[]
  sessions       Session[]
  accounts       Account[]

  @@map("user")
}


model Agency {
  id           String  @id @default(cuid())
  name         String
  websiteUrl   String?
  logoUrl      String?
  primaryColor String? @default("#10B981") 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  leads      Lead[]

  @@map("agencies")
}


model Property {
  id              String          @id @default(cuid())
  externalId      String? 
  title           String
  description     String?         @db.Text
  transactionType TransactionType
  propertyType    PropertyType
  price           Decimal         @db.Decimal(10, 2)
  city            String
  state           String
  neighborhood    String?
  isFurnished     Boolean         @default(false)
  billsIncluded   Boolean         @default(false)
  roomType        String?
  genderRules     String?
  bedrooms        Int             @default(0)
  bathrooms       Int             @default(0)
  parkingSpots    Int             @default(0)
  area            Decimal?        @db.Decimal(10, 2)
  mainImage       String
  gallery         String[] 
  interests Interest[]
  leadEvents LeadEvent[]
  status          PropertyStatus  @default(DISPONIVEL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  favorites Favorite[]
  leads     Lead[]


  @@unique([agencyId, externalId])
  @@map("properties")
}

model Interest {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@map("interests")
}


enum LeadEventType {
  interest_click
  whatsapp_click
}

model LeadEvent {
  id         String        @id @default(cuid())
  userId     String
  userName   String?
  userEmail  String?
  propertyId String
  eventType  LeadEventType
  createdAt  DateTime      @default(now())

  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([eventType])
  @@index([propertyId, eventType])
  @@map("lead_events")
}


model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Profile {
  id              String   @id
  name            String?
  plan            String?
  bedrooms        Int?
  parkingSpots    Int?
  bathrooms       Int?
  neighborhood    String?
  transactionType String?
  propertyType    String?
  maxPrice        Float?
  onboardingDone  Boolean  @default(false)
}

model Lead {
  id          String     @id @default(cuid())
  clientName  String
  clientPhone String
  origin      LeadOrigin
  aiSummary   String?    @db.Text
  status      LeadStatus @default(NOVO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("leads")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
